---
import logoImg from '../assets/images/general/logo-clown-nrw.png';
---

<footer style="background-color: #c8d0e7;" class="py-12">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- ANDERE KOLLEGEN -->
      <div>
        <h3 class="text-sm font-extrabold mb-5 text-[#1f2025] uppercase tracking-widest">Andere Kollegen</h3>
        <ul class="space-y-2 text-sm text-[#374151]">
          <li><a href="https://www.magic-olli.de/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Magic Olli</a></li>
          <li><a href="https://www.zauberer-berlin.de/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer Berlin</a></li>
          <li><a href="https://www.zauberer-duesseldorf.com/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer Düsseldorf</a></li>
          <li><a href="https://www.zauberer-bremen.de/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer in Bremen</a></li>
          <li><a href="https://www.zauberer-koeln.com/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer Köln</a></li>
          <li><a href="https://www.zauberer-koeln-umgebung.de/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer Köln und Umgebung</a></li>
          <li><a href="https://www.zauberer-schweiz.ch/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Zauberer Schweiz</a></li>
          <li><a href="https://www.kinderzauberer-hamburg.de/" target="_blank" rel="noopener noreferrer nofollow" class="hover:text-[#d7393e] transition-colors">Kinderzauberer Hamburg</a></li>
        </ul>
      </div>

      <!-- NEWS CLOWN ZAUBERER -->
      <div>
        <h3 class="text-sm font-extrabold mb-5 text-[#1f2025] uppercase tracking-widest">News Clown Zauberer</h3>
        <ul class="space-y-2 text-sm text-[#374151]">
          <li><a href="/blog/kindergeburtstag-park-tipps/" class="hover:text-[#d7393e] transition-colors">Kindergeburtstag im Park: Was muss man beachten? 🎂 🏕️</a></li>
          <li><a href="/blog/open-air-zauberei-im-freien/" class="hover:text-[#d7393e] transition-colors">Open-Air-Zauberei: Wie funktioniert eine Zaubershow im Freien? 🧙 🌿</a></li>
          <li><a href="/blog/sommerfest-kita-programm-clown-zauberer/" class="hover:text-[#d7393e] transition-colors">Sommerfest in der Kita planen: Programm-Ideen mit Clown und Zauberer 🎪 🌞</a></li>
          <li><a href="/blog/kindergeburtstag-hitze-outdoor-programm/" class="hover:text-[#d7393e] transition-colors">Kindergeburtstag bei Hitze: Outdoor-Programme die wirklich funktionieren ☀️ 🎈</a></li>
          <li><a href="/blog/kindergeburtstag-mai-outdoor-ruhrgebiet/" class="hover:text-[#d7393e] transition-colors">Kindergeburtstag im Mai ☀️ Outdoor-Ideen im Ruhrgebiet 🎈</a></li>
          <li><a href="/blog/muttertag-familiengeburtstag-kombinieren/" class="hover:text-[#d7393e] transition-colors">Muttertag &amp; Familiengeburtstag kombinieren – was zusammen funktioniert 🌸 🎂</a></li>
          <li><a href="/blog/fruehlings-sommerfeste-kindergarten/" class="hover:text-[#d7393e] transition-colors">🌸 Frühlings- und Sommerfeste im Kindergarten: Ideen für unvergessliche Events</a></li>
        </ul>
      </div>

      <!-- INFOS + HAUPTSEITEN -->
      <div>
        <h3 class="text-sm font-extrabold mb-5 text-[#1f2025] uppercase tracking-widest">Infos</h3>
        <img src={logoImg.src} alt="LOGO Clown Zauberer LIAR" class="h-10 w-auto mb-3" loading="lazy" />
        <p class="font-bold text-[#1f2025] mb-1">Clown Zauberer LIAR</p>
        <p class="text-sm text-[#374151] mb-1">Michaël Prescler</p>
        <p class="text-sm text-[#374151] mb-5">
          Tel: <a href="tel:+491721517578" class="hover:text-[#d7393e] transition-colors">0172-1517578</a><br />
          Email: <a href="mailto:info@liar-entertainer.com" class="hover:text-[#d7393e] transition-colors">info@liar-entertainer.com</a>
        </p>

        <h4 class="text-sm font-extrabold mb-3 text-[#1f2025] uppercase tracking-widest">Hauptseiten</h4>
        <ul class="space-y-1 text-sm text-[#374151]">
          <li><a href="/clown/clownshow/" class="hover:text-[#d7393e] transition-colors">Clownshow</a></li>
          <li><a href="/zauberer/" class="hover:text-[#d7393e] transition-colors">Zauberer</a></li>
          <li><a href="/kinderzauberer/" class="hover:text-[#d7393e] transition-colors">Kinderzauberer</a></li>
          <li><a href="/kindergeburtstag/" class="hover:text-[#d7393e] transition-colors">Kindergeburtstag</a></li>
          <li><a href="/zauberer/zaubershow/" class="hover:text-[#d7393e] transition-colors">Zaubershow</a></li>
          <li><a href="/galerie/" class="hover:text-[#d7393e] transition-colors">Galerie</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar: Logo + Copyright + Nav -->
    <div class="border-t border-[#b0bbd4] pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <img
          src={logoImg.src}
          alt="LOGO Clown Zauberer LIAR"
          class="h-3 w-auto"
          loading="lazy"
        />
        <p class="text-sm text-[#374151]">
          &copy; {new Date().getFullYear()} Clown Zauberer LIAR – Alle Rechte vorbehalten
        </p>
      </div>
      <nav class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-[#374151] justify-center md:justify-end">
        <a href="/kontakt/" class="hover:text-[#d7393e] transition-colors">Kontakt</a>
        <a href="/galerie/" class="hover:text-[#d7393e] transition-colors">Galerie</a>
        <a href="/ueber-mich/" class="hover:text-[#d7393e] transition-colors">Über mich</a>
        <a href="/impressum/" class="hover:text-[#d7393e] transition-colors">Impressum</a>
        <a href="/datenschutzerklaerung-2/" class="hover:text-[#d7393e] transition-colors">Datenschutz</a>
        <a href="/agbs/" class="hover:text-[#d7393e] transition-colors">AGB</a>
      </nav>
    </div>

  </div>
</footer>
