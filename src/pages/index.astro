---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import { Image, getImage } from 'astro:assets';

import heroImg from '../assets/images/home/clown-zauberer-hero.jpg';
const heroOptimized = await getImage({ src: heroImg, width: 1200, format: 'webp' });
import portraitImg from '../assets/images/home/clown-zauberer-liar-portrait.jpg';
import michaelImg from '../assets/images/home/michael-prescler-portrait.jpg';
import clownerieImg from '../assets/images/home/clownerie-und-zauberei.jpg';
import zaubershowImg from '../assets/images/shows/zaubershow.jpg';
import ballonImg from '../assets/images/shows/ballonmodellage.jpg';
import glitzerImg from '../assets/images/shows/glitzer-tattoos.jpg';
import karteImg from '../assets/images/home/clown-zauberer-gladbeck-karte.jpg';

const title = 'Clown Zauberer NRW | Kindergeburtstag & Events | LIAR';
const description = 'Clown Zauberer LIAR in NRW ✓ Zaubershow & Clownshow ✓ Kindergeburtstag ab 150€ ✓ 400+ Top-Bewertungen ✓ Ballonmodellage & Glitzer-Tattoos ✓ Jetzt buchen!';
const ogImage = 'https://liar-entertainer.com/images/og-startseite.jpg';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Clown für Kindergeburtstag?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine professionelle Clown-Show von LIAR beginnt ab 150€. Der genaue Preis hängt von der gewünschten Leistung, Dauer und Anfahrt ab."
      }
    },
    {
      "@type": "Question",
      "name": "In welchen Städten ist Clown LIAR buchbar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Clown LIAR ist in ganz NRW buchbar, insbesondere in Gladbeck, Oberhausen, Essen, Gelsenkirchen, Dortmund, Bochum, Duisburg und weiteren Städten."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Clown Zaubershow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Standard-Zaubershow dauert ca. 40 Minuten und ist speziell auf Kinder von 3-12 Jahren zugeschnitten."
      }
    },
    {
      "@type": "Question",
      "name": "Ist Clown LIAR ein \"gruseliger\" Clown?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein! Clown LIAR tritt bewusst ohne Schminke, ohne rote Nase und ohne \"komische Haare\" auf. Sein Clown-Charakter ist freundlich, bunt und einladend. Selbst schüchterne Kinder tauen schnell auf."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich Clown LIAR auch für Erwachsenen-Events buchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja! Neben Kindergeburtstagen bietet Clown Zauberer LIAR auch Close-up Zauberei für Hochzeiten, Firmenfeiern und Gala-Events an. Die Tischzauberei funktioniert ohne Bühne direkt an den Tischen Ihrer Gäste."
      }
    },
    {
      "@type": "Question",
      "name": "Wie weit im Voraus sollte ich buchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine Anfrage mindestens 2-4 Wochen im Voraus wird empfohlen, besonders an Wochenenden. Kurzfristige Buchungen sind aber oft auch möglich – einfach unter 0172-1517578 anrufen!"
      }
    },
    {
      "@type": "Question",
      "name": "Brauche ich eine Bühne oder spezielle Technik?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein! Es werden nur 2×2 Meter Platz benötigt. Die Show funktioniert im Wohnzimmer, Garten, Turnhalle oder auf einer Bühne. Alles Nötige wird mitgebracht."
      }
    },
    {
      "@type": "Question",
      "name": "Für welches Alter ist die Show geeignet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Shows sind für Kinder von 3 bis 12 Jahren konzipiert. Das Programm wird immer an die Altersgruppe angepasst: einfacher und kürzer für Kindergartenkinder, anspruchsvoller für Grundschulkinder."
      }
    },
    {
      "@type": "Question",
      "name": "Was passiert bei schlechtem Wetter (Outdoor-Event)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Show ist flexibel und funktioniert drinnen wie draußen. Falls ein Outdoor-Event wegen Regen ins Haus verlegt werden muss, ist das kein Problem – es werden nur 2×2 Meter Platz benötigt."
      }
    },
    {
      "@type": "Question",
      "name": "Hat Clown LIAR eine Versicherung und ein Führungszeugnis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, Clown Zauberer LIAR ist vollständig haftpflichtversichert und verfügt über ein aktuelles polizeiliches Führungszeugnis, das auf Anfrage vorgelegt wird."
      }
    }
  ]
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Michaël Prescler",
  "alternateName": "Clown Zauberer LIAR",
  "jobTitle": "Professioneller Clown & Zauberer",
  "description": "Professioneller Kinderzauberer und Clown mit über 15 Jahren Erfahrung und pädagogischer Ausbildung in NRW",
  "knowsAbout": ["Zauberei", "Clownerie", "Kinderunterhaltung", "Ballonmodellage", "Close-up Magie"],
  "knowsLanguage": ["de", "fr"],
  "worksFor": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com"
  },
  "url": "https://liar-entertainer.com"
};
const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!",
  "description": "Clown Zauberer LIAR zeigt seine Zaubershow und Clownshow für Kinder in NRW. Kindergeburtstag ab 150€ – professionell, lustig und unvergesslich.",
  "thumbnailUrl": "https://img.youtube.com/vi/Cop0SqRIX4Y/maxresdefault.jpg",
  "uploadDate": "2018-02-04",
  "duration": "PT2M30S",
  "contentUrl": "https://www.youtube.com/watch?v=Cop0SqRIX4Y",
  "embedUrl": "https://www.youtube.com/embed/Cop0SqRIX4Y",
  "publisher": {
    "@type": "Organization",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  keywords="Clown Kindergeburtstag NRW, Zauberer Kindergeburtstag, Clown Zauberer NRW, Zaubershow Kinder, Kinderzauberer NRW, Clown buchen NRW, Kindergeburtstag Zauberer"
  canonical="https://liar-entertainer.com/"
  ogImage={ogImage}
  structuredData={[faqSchema, personSchema, videoSchema]}
  heroPreload={heroOptimized.src}
>

  <style>
    /* Startseite: Content-Texte auf 17px */
    section p:not([class*="text-xs"]):not([class*="text-sm"]):not([class*="uppercase"]),
    section li,
    section dd { font-size: 17px; }
  </style>

  <!-- ═══════════════════════════════════════
       HERO IMAGE – full width, no overlay
  ════════════════════════════════════════ -->
  <section class="w-full overflow-hidden">
    <Image
      src={heroImg}
      alt="Clown Zauberer LIAR bei einer Zaubershow"
      class="w-full object-cover"
      style="max-height:720px; width:100%; object-position:52% 0%;"
      loading="eager"
      fetchpriority="high"
      widths={[600, 900, 1200]}
      sizes="100vw"
      quality={70}
    />
  </section>

  <!-- ═══════════════════════════════════════
       INTRO – H1 + lead paragraph (centered)
  ════════════════════════════════════════ -->
  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-[#1f2025] font-extrabold text-3xl sm:text-5xl lg:text-6xl leading-tight mb-8">
        Clown Zauberer in NRW – Zaubershow & Kindergeburtstag
      </h1>
      <p class="text-[#374151] text-[17px] sm:text-lg leading-relaxed">
        Sie suchen einen Clown, der Kinderaugen zum Leuchten bringt? Clown Zauberer Liar sorgt seit
        über 15 Jahren für unvergessliche Momente auf <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstagen</a>, Straßenfesten und
        Firmenevents in ganz NRW. Als erfahrener <a href="/kinderzauberer/" class="text-[#d7393e] hover:underline font-semibold">Kinderzauberer</a> und
        <a href="/clown/clownshow/" class="text-[#d7393e] hover:underline font-semibold">Clown</a> verbindet er professionelle
        <a href="/zauberer/" class="text-[#d7393e] hover:underline font-semibold">Zauberei</a>
        mit Interaktion — jede Veranstaltung wird zum Highlight!
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WAS MACHT CLOWN LIAR SO BESONDERS?
  ════════════════════════════════════════ -->
  <section class="py-10 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-extrabold text-2xl sm:text-3xl mb-8">
        Was macht Clown Liar so besonders?
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div class="space-y-5">
          <p class="text-[#374151] leading-relaxed">
            Als professioneller Clown und Kinderzauberer bringe ich nicht nur Kinder, sondern auch Erwachsene zum Lachen.
            Meine Show kombiniert klassische Clownerie mit modernen Entertainment-&nbsp;Elementen –
            individuell abgestimmt auf Ihr Event und die Altersgruppe. Ob beim <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a> oder auf der großen Bühne.
          </p>
          <p class="text-[#374151] leading-relaxed">
            <span class="text-lg mr-1">✨</span>
            <a href="/zauberer/zaubershow/" class="text-[#d7393e] hover:underline font-semibold">Zaubershow</a>
            : Verblüffende Zaubertricks, bei denen die Kinder aktiv mitmachen und selbst zu
            kleinen Zauberern werden. Staunen und Lachen in perfekter Balance!
          </p>
          <p class="text-[#374151] leading-relaxed">
            <span class="text-lg mr-1">🎭</span>
            Walk-Act : Lustige Improvisation, witzige Gags und interaktive Clownerie, die garantiert
            für Lacher sorgt. Jeder Pantomime- oder Clown-Auftritt wird auf Ihre Gäste abgestimmt.
          </p>
          <p class="text-[#374151] leading-relaxed">
            <span class="text-lg mr-1">🎈</span>
            Extras : Ballonmodellage, Glitzer Tattoos, Close-up… Ihr Clown Zauberer bringt alles
            mit, was Ihr Event unvergesslich macht.
          </p>
        </div>
        <div class="flex justify-center lg:justify-end">
          <Image
            src={portraitImg}
            alt="Clown Zauberer LIAR bringt Kinder auf dem Geburtstag zum Lachen"
            class="rounded-full object-cover object-[20%] portrait-zoom"
            style="width:320px;height:320px;"
            loading="lazy"
            width={320}
            height={320}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews (dynamisch) -->
  <GoogleReviews />

  <!-- ═══════════════════════════════════════
       LERNEN SIE CLOWN LIAR KENNEN
  ════════════════════════════════════════ -->
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-extrabold text-2xl sm:text-3xl mb-8">
        Lernen Sie Clown Liar kennen – Ihr Entertainer mit Herz &amp; Humor
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#374151] leading-relaxed mb-4">
            Hallo, ich bin Liar – professioneller Clown, Zauberer und Entertainer aus
            Nordrhein-Westfalen und seit über einem Jahrzehnt bringe ich Kinderherzen zum
            Hüpfen und Erwachsene zum Schmunzeln. <a href="/ueber-mich/" class="text-[#d7393e] hover:underline">Erfahren Sie mehr über mich und meinen Werdegang</a>.
          </p>
          <p class="text-[#374151] leading-relaxed">
            Meine Mission? Jeden Moment zu etwas Besonderem machen! Daher ist es mir als
            Clown wichtig, dass sich jedes Kind gesehen und einbezogen fühlt. Deshalb sind
            meine Shows interaktiv, warmherzig und voller Überraschungen. In meinem <a href="/blog/" class="text-[#d7393e] hover:underline">Blog</a> erzähle ich regelmäßig von solchen besonderen Momenten.
          </p>
        </div>
        <div class="flex justify-center">
          <Image
            src={michaelImg}
            alt="Foto von Michael Prescler – Clown Zauberer LIAR"
            class="rounded-full object-cover object-[20%] portrait-zoom"
            style="width:280px;height:280px;"
            loading="lazy"
            width={280}
            height={280}
            quality={70}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WAVE → RED STATS SECTION
  ════════════════════════════════════════ -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <section class="bg-[#d7393e] py-10 text-white text-center">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white/15 rounded-xl p-6 stat-card-pulse">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">400</div>
          <div class="text-sm mt-1">Shows im Jahr</div>
        </div>
        <div class="bg-white/15 rounded-xl p-6 stat-card-pulse">
          <div class="text-3xl mb-2">😊</div>
          <div class="text-4xl font-extrabold">110.000</div>
          <div class="text-sm mt-1">Lachende Kinder</div>
        </div>
        <div class="bg-white/15 rounded-xl p-6 stat-card-pulse">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">15</div>
          <div class="text-sm mt-1">Jahre Erfahrung</div>
        </div>
      </div>
    </div>
  </section>

  <div style="overflow:hidden;line-height:0;background:#d7393e;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════
       QUALIFIKATIONEN + WAS MICH AUSZEICHNET
  ════════════════════════════════════════ -->
  <section class="pt-4 pb-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="font-bold text-[#1f2025] text-lg mb-4">Meine Qualifikationen:</p>
          <div class="space-y-3">
            {[
              'Über 15 Jahre Erfahrung als Clown & 30 Jahre als Entertainer',
              'über 400 erfolgreiche Auftritte in NRW und deutschlandweit im Jahr',
              'pädagogische Ausbildung',
              'Spezialisiert auf Kinder von 3–12 Jahren',
              'Versichert und polizeiliches Führungszeugnis(auf Anfrage)',
            ].map((item) => (
              <p class="text-[#374151] leading-relaxed flex items-start gap-2">
                <span class="text-green-600 flex-shrink-0 mt-0.5">✅</span>
                <span>{item}</span>
              </p>
            ))}
          </div>
        </div>
        <div class="flex justify-center">
          <Image
            src={clownerieImg}
            alt="Clownerie und Zauberei auf einem Kindergeburtstag in NRW"
            class="rounded-full object-cover object-[20%] portrait-zoom"
            style="width:260px;height:260px;"
            loading="lazy"
            width={260}
            height={260}
          />
        </div>
      </div>

      <!-- Was mich als Clown auszeichnet -->
      <div class="mt-14 text-center max-w-2xl mx-auto">
        <p class="font-bold text-[#1f2025] text-lg mb-4">** Was mich als Clown auszeichnet **</p>
        <p class="text-[#374151] leading-relaxed">
          Ich bin kein „gruseliger" Clown – ganz im Gegenteil : keine Schminke, keine
          „komischen Haare" und keine rote Nase! Mein Clown-Charakter ist freundlich,
          trotzdem bunt und lädt Kinder zum Mitmachen ein. Selbst schüchterne Kinder
          tauen schnell auf, wenn Clown Liar die Bühne betritt.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WAVE → BLUE SERVICES SECTION
  ════════════════════════════════════════ -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════
       DAS BIETET CLOWN ZAUBERER LIAR
  ════════════════════════════════════════ -->
  <section class="bg-[#3b55d5] pt-6 pb-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-white font-extrabold text-2xl sm:text-3xl text-center mb-12">
        Das bietet Clown Zauberer Liar für Ihr Event
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">

        <!-- Zaubershow -->
        <div class="text-center text-white">
          <a href="/zauberer/zaubershow/">
            <Image
              src={zaubershowImg}
              alt="Clown Zauberer LIAR verzaubert Kinder bei einer Zaubershow in NRW"
              class="rounded-full object-cover object-[20%] mx-auto portrait-zoom"
              style="width:220px;height:220px;"
              loading="lazy"
              width={220}
              height={220}
            />
          </a>
          <h3 class="font-extrabold text-xl mt-5 mb-3 tracking-wide">ZAUBERSHOW</h3>
          <p class="text-white/90 text-sm leading-relaxed mb-3">
            Clown trifft Zauberer – Die magischste Show in NRW! Wenn der Clown zum Zauberer wird,
            passieren unglaubliche Dinge! Meine Zaubershow ist speziell für Kinder konzipiert und
            verbindet Comedy mit verblüffender Magie.
          </p>
          <div class="text-white/80 text-sm space-y-1.5 text-left">
            <p>✅ <strong>Interaktive Zaubertricks</strong> – Kinder werden zu Co-Zauberern und erleben Magie hautnah</p>
            <p>✅ <strong>Altersgerechte Magie</strong> – Von einfachen Tricks für die Kleinen bis zu verblüffenden Illusionen für ältere Kinder</p>
            <p>✅ <strong>Comedy-Magie</strong> – Der Clown zaubert nicht perfekt – und genau das macht es so lustig!</p>
            <p>✅ <strong>Große Finale</strong> – Ein spektakulärer Abschlusszauber, den niemand vergisst</p>
          </div>
          <p class="text-white/90 text-xs mt-3"><strong>Dauer:</strong> ca. 40 Minuten</p>
          <a href="/zauberer/zaubershow/" class="inline-block mt-4 text-white hover:underline text-sm font-semibold">
            Mehr erfahren →
          </a>
        </div>

        <!-- Ballonmodellage -->
        <div class="text-center text-white">
          <a href="/clown/ballonmodellage/">
            <Image
              src={ballonImg}
              alt="Clown LIAR formt Ballontiere bei Ballonmodellage auf Kindergeburtstag"
              class="rounded-full object-cover object-[20%] mx-auto portrait-zoom"
              style="width:220px;height:220px;"
              loading="lazy"
              width={220}
              height={220}
            />
          </a>
          <h3 class="font-extrabold text-xl mt-5 mb-3 tracking-wide">BALLONMODELLAGE</h3>
          <p class="text-white/90 text-sm leading-relaxed mb-3">
            Bunte Ballontiere vom Clown – Jedes Kind bekommt sein Wunschtier! Welches Kind liebt
            nicht Ballontiere? Als erfahrener Clown und Ballonkünstler forme ich im Handumdrehen
            die schönsten Figuren:
          </p>
          <div class="text-white/80 text-sm space-y-1.5 text-left">
            <p>✅ Klassiker: Hund, Katze, Herz, Schwert, Blume</p>
            <p>✅ Spezial-Figuren: Wikinger Helm, Dinosaurier, Kronen, Marienkäfer</p>
            <p>✅ Individuelle Wünsche werden erfüllt!</p>
          </div>
          <p class="text-white/90 text-xs mt-3"><strong>Dauer:</strong> Je nach Kinderzahl (ca. 1-2 Minuten pro Figur)</p>
          <a href="/clown/ballonmodellage/" class="inline-block mt-4 text-white hover:underline text-sm font-semibold">
            Mehr erfahren →
          </a>
        </div>

        <!-- Glitzer Tattoos -->
        <div class="text-center text-white">
          <a href="/clown/glitzer-tattoo/">
            <Image
              src={glitzerImg}
              alt="Glitzer Tattoos von Clown Zauberer LIAR auf einem Kinderfest in NRW"
              class="rounded-full object-cover object-[20%] mx-auto portrait-zoom"
              style="width:220px;height:220px;"
              loading="lazy"
              width={220}
              height={220}
            />
          </a>
          <h3 class="font-extrabold text-xl mt-5 mb-3 tracking-wide">GLITZER TATTOOS</h3>
          <p class="text-white/90 text-sm leading-relaxed mb-3">
            Funkel-Glamour vom Clown – Temporäre Tattoos mit WOW-Effekt! Glitzer Tattoos sind
            der Hit auf jeder Party! Als Clown bringe ich eine große Auswahl an glitzernden
            Motiven mit, die Kinderaugen leuchten lassen:
          </p>
          <div class="text-white/80 text-sm space-y-1.5 text-left">
            <p>✅ <strong>Hautverträglich &amp; sicher</strong> – Dermatologisch getestet, keine Allergene</p>
            <p>✅ <strong>Riesige Motivauswahl</strong></p>
            <p>✅ <strong>Schnell &amp; sauber</strong> – In 2-3 Minuten fertig, kein Rumschmieren</p>
            <p>✅ <strong>Hält mehrere Tage</strong> – Wasserfest und wischfest</p>
            <p>✅ <strong>Für Jungs &amp; Mädchen</strong> – Superhelden, Tiere, Blumen, Sterne u.v.m.</p>
          </div>
          <p class="text-white/90 text-xs mt-3"><strong>Dauer:</strong> Ca. 2-3 Minuten pro Tattoo</p>
          <a href="/clown/glitzer-tattoo/" class="inline-block mt-4 text-white hover:underline text-sm font-semibold">
            Mehr erfahren →
          </a>
        </div>

      </div>
    </div>
  </section>

  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
